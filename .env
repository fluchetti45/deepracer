# Camara estilo DeepRacer: 160x120 RGB (la observacion). Debe coincidir con el width/
# height de la Camera en el .wbt. CHANNELS=3 (RGB) porque el reward usa color; pasar la
# policy a grises es una mejora posterior (desacoplando obs del reward).
CAMERA_WIDTH = 160
CAMERA_HEIGHT = 120
CAMERA_CHANNELS = 3

# Tipo de conduccion: "ackermann" (auto) o "differential" (e-puck). Selecciona el world
# y filtra los tracks de spawns.json (solo los del mismo "drive"). trainer/evaluate lo
# pisan con --drive.
DRIVE_TYPE = ackermann

# Accion DeepRacer: [steering, speed]. speed [-1,1] -> [WHEEL_MIN_SPEED, WHEEL_MAX_SPEED]
# rad/s (ambas positivas: nunca reversa ni freno total).
WHEEL_MIN_SPEED = 3.0
WHEEL_MAX_SPEED = 8.0
# Angulo maximo de direccion (Ackermann), en grados. DeepRacer real: ~30.
MAX_STEER_ANGLE_DEG = 30.0
# Geometria del auto para la direccion Ackermann real (m). Deben coincidir con el .wbt.
WHEELBASE = 0.16
TRACK_WIDTH = 0.13

# Normalizacion de velocidad: ~vmax real = WHEEL_MAX_SPEED * radio_rueda (5.0 * 0.03)
MAX_LINEAR_SPEED = 0.15

# Reward: reward = clearance * (REWARD_BASE + REWARD_SPEED_W * speed) + penas
# REWARD_SPEED_W vs OFFTRACK_PENALTY = trade-off velocidad/seguridad
REWARD_BASE = 0.0
REWARD_SPEED_W = 1.0
REWARD_OFFSET_W = 0.0
REWARD_WHITE_W = 0.0
REWARD_STEP_COST = 0.03
OFFTRACK_PENALTY = -1.0
# Steps seguidos con pasto en el centro antes de cortar por off-track (gracia para
# curvas). 1 = inmediato. evaluate.py lo puede subir con --offtrack-grace.
OFFTRACK_MAX_STEPS = 3

# Domain randomization de la pose al inicio de cada episodio (jitter sobre el spawn)
DOMAIN_RANDOMIZATION_ENABLED = 1
DOMAIN_RANDOMIZATION_PROBABILITY = 0.3
DOMAIN_RANDOMIZATION_MAX_ROTATION_DEG = 15.0
DOMAIN_RANDOMIZATION_MAX_TRANSLATION = 0.01

# Time limit por episodio SOLO en evaluacion (rl/evaluate.py): steps maximos para
# completar una vuelta antes de truncar por timeout. No afecta el training.
EVAL_MAX_EPISODE_STEPS = 2000

# Progreso por gates (si el track tiene "gates" en spawns.json)
REWARD_PROGRESS_W = 1.0      # peso del avance sobre el circuito (reemplaza a velocidad)
LAP_BONUS = 5.0              # reward terminal al completar una vuelta
WRONG_WAY_PENALTY = -1.5     # reward terminal por ir en contramano
WRONG_WAY_MAX_STEPS = 12     # steps de retroceso seguidos antes de cortar