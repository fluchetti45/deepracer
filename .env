CAMERA_WIDTH = 84
CAMERA_HEIGHT = 84
CAMERA_CHANNELS = 3

# Mapeo de accion por rueda: [-1,1] -> [WHEEL_MIN_SPEED, WHEEL_MAX_SPEED] rad/s
# (ambas positivas: nunca reversa ni freno total)
WHEEL_MIN_SPEED = 1.5
WHEEL_MAX_SPEED = 5.0

# Radio de rueda (m) y tope fisico del motor (rad/s). El supervisor aplica
# MOTOR_MAX_SPEED al maxVelocity de los motores al arrancar (getFromDef) -> el tope se
# controla desde aca, sin editar el .wbt. Poner headroom para calibrar; >= WHEEL_MAX_SPEED.
WHEEL_RADIUS = 0.02
MOTOR_MAX_SPEED = 20.0

# Normalizacion de velocidad (divisor): se DERIVA solo de WHEEL_MAX_SPEED * WHEEL_RADIUS
# para seguir siempre al rango calibrado. Descomentar SOLO para forzar un override manual.
# MAX_LINEAR_SPEED = 0.1

# Reward: reward = clearance * (REWARD_BASE + REWARD_SPEED_W * speed) + penas
# REWARD_SPEED_W vs OFFTRACK_PENALTY = trade-off velocidad/seguridad
REWARD_BASE = 0.0
REWARD_SPEED_W = 1.0
REWARD_OFFSET_W = 0.3
REWARD_WHITE_W = 0.1
REWARD_STEP_COST = 0.03
OFFTRACK_PENALTY = -10.0

# Deteccion de carril / off-track por color (helpers/lane_vision.py). El pasto se detecta
# por umbrales RGB sobre la banda inferior de la camara; si la banda central supera
# OFFTRACK_GREEN_FRAC de pasto => off-track terminal. Calibrar con center_rgb de la robot
# window. El fondo oficial (PMS 3395 C) renderiza ~[10,175,157] (verde-azulado): por eso
# NO se exige que el verde le gane al azul, solo que el azul no lo supere por > SLACK.
LANE_WHITE_MIN = 175          # borde blanco: R,G,B todos >= esto
LANE_GREEN_G_MIN = 60         # pasto: canal verde minimo
LANE_GREEN_MARGIN = 25        # pasto: cuanto le gana el verde al rojo (g - r >= esto)
LANE_GREEN_BLUE_SLACK = 40    # pasto: cuanto puede superar el azul al verde (b - g <= esto)
OFFTRACK_GREEN_FRAC = 0.4     # fraccion de pasto en la banda central para declarar off-track
OFFTRACK_GRACE_STEPS = 6      # pasos consecutivos sobre pasto antes de terminar (gracia)

# Domain randomization de la pose al inicio de cada episodio (jitter sobre el spawn)
DOMAIN_RANDOMIZATION_ENABLED = 1
DOMAIN_RANDOMIZATION_PROBABILITY = 0.3
DOMAIN_RANDOMIZATION_MAX_ROTATION_DEG = 15.0
DOMAIN_RANDOMIZATION_MAX_TRANSLATION = 0.01

# Domain randomization VISUAL del fondo: color de las paredes de la arena aleatorio por
# episodio (evita que la CNN se sesgue a la textura/color del fondo). El eval lo apaga.
BACKGROUND_RANDOMIZATION_ENABLED = 1
BACKGROUND_RANDOMIZATION_PROBABILITY = 0.8

# Time limit por episodio en TRAINING (truncado). DEBE ser > el largo de una vuelta (~1080
# steps) para que el agente complete vueltas y experimente el LAP_BONUS; con 1000 (default
# viejo) NINGUNA vuelta entraba. ~2500 deja ~2 vueltas + red de seguridad anti-loop.
MAX_EPISODE_STEPS = 2500

# Time limit por episodio SOLO en evaluacion (rl/evaluate.py): steps maximos para
# completar una vuelta antes de truncar por timeout. No afecta el training.
EVAL_MAX_EPISODE_STEPS = 2000

# Progreso por gates (si el track tiene "gates" en spawns.json)
REWARD_PROGRESS_W = 1.0      # peso del avance sobre el circuito (reemplaza a velocidad)
LAP_BONUS = 50.0             # reward terminal al completar una vuelta (subido de 5: con gamma=0.995 era casi irrelevante)
WRONG_WAY_PENALTY = -1.5     # reward terminal por ir en contramano
WRONG_WAY_MAX_STEPS = 12     # steps de retroceso seguidos antes de cortar