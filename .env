CAMERA_WIDTH = 84
CAMERA_HEIGHT = 84
CAMERA_CHANNELS = 3

# Mapeo de accion por rueda: [-1,1] -> [WHEEL_MIN_SPEED, WHEEL_MAX_SPEED] rad/s
# (ambas positivas: nunca reversa ni freno total)
WHEEL_MIN_SPEED = 0.75
WHEEL_MAX_SPEED = 5.0

# Normalizacion de velocidad: ~vmax real = WHEEL_MAX_SPEED * radio (5.0 * 0.02)
MAX_LINEAR_SPEED = 0.1

# Reward: reward = clearance * (REWARD_BASE + REWARD_SPEED_W * speed) + penas
# REWARD_SPEED_W vs OFFTRACK_PENALTY = trade-off velocidad/seguridad
REWARD_BASE = 0.1
REWARD_SPEED_W = 1.0
REWARD_OFFSET_W = 0.3
REWARD_WHITE_W = 0.5
REWARD_STEP_COST = 0.0
OFFTRACK_PENALTY = -1.0

# Domain randomization de la pose al inicio de cada episodio (jitter sobre el spawn)
DOMAIN_RANDOMIZATION_ENABLED = 1
DOMAIN_RANDOMIZATION_PROBABILITY = 0.3
DOMAIN_RANDOMIZATION_MAX_ROTATION_DEG = 15.0
DOMAIN_RANDOMIZATION_MAX_TRANSLATION = 0.01